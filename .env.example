# ========================================================
#   MATRIX ORACLE NEURAL INTERFACE - CONFIGURATION KEYS
# ========================================================

# --- Server Host & Port Configurations ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
FRONTEND_PORT=3000

# --- LLM API Providers ---
# Required for Google Gemini models (e.g. gemini-2.5-flash) and Embeddings (text-embedding-004)
GOOGLE_API_KEY=your_gemini_api_key_here

# Required for NVIDIA NIM models (e.g. nvidia/llama-3.1-nemotron-70b-instruct)
NVIDIA_API_KEY=nvapi-your_nvidia_nim_api_key_here

# Required for Groq Core models (e.g. llama-3.3-70b-versatile, mixtral-8x7b-32768)
GROQ_API_KEY=gsk_your_groq_api_key_here


# --- Database & Storage Configurations ---
# Local RAG Ingestion directory (defaults to 'uploads' in parent directory)
UPLOAD_DIR=

# By default, the system runs on a local SQLite file (chat_history.db).
# To scale to PostgreSQL in production, configure either DATABASE_URL or the parameters below:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/matrix_oracle

POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=


# --- Redis Cache Config ---
# Used for LLM completion caching and document context caching
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=


# --- Development & Testing Settings ---
# Force in-memory database execution for unit testing (set dynamically in run_tests.bat)
TESTING=False
